<UserControl x:Class="Dear_Doctor.Views.PrescriptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dear_Doctor.Views"
             xmlns:localControls="clr-namespace:Dear_Doctor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F8FAFC">
    <UserControl.Resources>
        <local:IndexConverter x:Key="IndexConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:CategoryFilterConverter x:Key="CategoryFilterConverter"/>
        <local:CategoryVisibilityConverter x:Key="CategoryVisibilityConverter"/>
        <local:EvenOddBackgroundConverter x:Key="EvenOddBackgroundConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/> <!-- Form Editor -->
            <ColumnDefinition Width="1*"/>   <!-- Live Print Preview -->
        </Grid.ColumnDefinitions>

        <!-- Left Column: Form Editor -->
        <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Background="#F8FAFC">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Screen Title -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="New Prescription" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Fill patient info and prescribe medicines below." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Scrollable Form -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Patient Information Card -->
                        <Border Background="#FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Patient Information" FontSize="16" FontWeight="Bold" Foreground="#0F766E" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Patient Name -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Patient Name" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="PatientNameInput" Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding PatientName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <!-- Age -->
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Text="Age" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="AgeInput" Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <!-- Gender -->
                                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                        <TextBlock Text="Gender" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <ComboBox x:Name="GenderInput" 
                                                  Height="38" 
                                                  Background="#FFFFFF"
                                                  BorderBrush="#E2E8F0"
                                                  BorderThickness="1"
                                                  Padding="10,6"
                                                  SelectedValuePath="Content"
                                                  SelectedValue="{Binding Gender, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="Male" IsSelected="True"/>
                                            <ComboBoxItem Content="Female"/>
                                            <ComboBoxItem Content="Other"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Date -->
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Date" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="DateInput" Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding Date, StringFormat={}{0:dd-MM-yyyy}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Clinical Notes & Vitals -->
                        <Border Background="#FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Clinical Details" FontSize="16" FontWeight="Bold" Foreground="#0F766E" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- B.P. -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                        <TextBlock Text="Blood Pressure (B.P)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="BPInput" Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding BP, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <!-- P.R. (Pulse Rate) -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                        <TextBlock Text="Pulse Rate (P.R)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="PRInput" Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding PR, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <!-- Chief Complaints (C/O) -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                        <TextBlock Text="Chief Complaints (C/O)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="ComplaintsInput" Style="{StaticResource PremiumTextBoxStyle}" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" Text="{Binding ChiefComplaints, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <!-- Diagnosis -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Most Probable Diagnosis" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="DiagnosisInput" Style="{StaticResource PremiumTextBoxStyle}" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <!-- Advice -->
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Advice" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                        <TextBox x:Name="AdviceInput" Style="{StaticResource PremiumTextBoxStyle}" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" Text="{Binding Advice, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Complications -->
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="Complications" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" FontSize="12"/>
                                    <TextBox x:Name="ComplicationsInput" Style="{StaticResource PremiumTextBoxStyle}" AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto" Text="{Binding Complication, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Medicines Rx Grid -->
                        <Border Background="#FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="16" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Medicines (Rx)" FontSize="16" FontWeight="Bold" Foreground="#0F766E" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+ Add Medicine Row" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" FontSize="12" Click="AddRowButton_Click"/>
                                </Grid>

                                <!-- Column Headers for Medicine Grid -->
                                <Border Background="#F8FAFC" Padding="8,6" Margin="0,0,0,4" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/> <!-- No. -->
                                            <ColumnDefinition Width="4.6*"/>  <!-- Medicine -->
                                            <ColumnDefinition Width="1.0*"/> <!-- Dose -->
                                            <ColumnDefinition Width="1.0*"/> <!-- Duration -->
                                            <ColumnDefinition Width="1.0*"/> <!-- Instruction -->
                                            <ColumnDefinition Width="40"/>  <!-- Actions -->
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" Foreground="#64748B" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="Medicine &amp; Composition" FontWeight="SemiBold" Foreground="#64748B" FontSize="11"/>
                                        <TextBlock Grid.Column="2" Text="Dosage" FontWeight="SemiBold" Foreground="#64748B" FontSize="11"/>
                                        <TextBlock Grid.Column="3" Text="Duration" FontWeight="SemiBold" Foreground="#64748B" FontSize="11"/>
                                        <TextBlock Grid.Column="4" Text="Instruction" FontWeight="SemiBold" Foreground="#64748B" FontSize="11"/>
                                    </Grid>
                                </Border>

                                <!-- List of Medicines -->
                                <ItemsControl x:Name="MedicinesItemsControl" ItemsSource="{Binding Medicines}" AlternationCount="1000">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/> <!-- No. -->
                                                    <ColumnDefinition Width="4.6*"/>  <!-- Medicine -->
                                                    <ColumnDefinition Width="1.0*"/> <!-- Dose -->
                                                    <ColumnDefinition Width="1.0*"/> <!-- Duration -->
                                                    <ColumnDefinition Width="1.0*"/> <!-- Instruction -->
                                                    <ColumnDefinition Width="40"/>  <!-- Actions -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Serial Number -->
                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource IndexConverter}}" 
                                                           VerticalAlignment="Center" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="#64748B"
                                                           Margin="4,0,0,0"/>

                                                <!-- AutoComplete Medicine TextBox -->
                                                <localControls:AutoCompleteTextBox Grid.Column="1" 
                                                                                    x:Name="MedicineInput"
                                                                                    Text="{Binding MedicineName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Suggestions="{Binding AllMedicines, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    MedicineSelected="MedicineInput_MedicineSelected"
                                                                                    Margin="0,0,8,0"/>

                                                <!-- Dosage -->
                                                <TextBox Grid.Column="2" 
                                                         x:Name="DoseInput"
                                                         Style="{StaticResource PremiumTextBoxStyle}"
                                                         Text="{Binding Dose, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="DoseInput_PreviewKeyDown"
                                                         Margin="0,0,8,0"/>

                                                <!-- Duration -->
                                                <TextBox Grid.Column="3" 
                                                         x:Name="DurationInput"
                                                         Style="{StaticResource PremiumTextBoxStyle}"
                                                         Text="{Binding Duration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="DurationInput_PreviewKeyDown"
                                                         Margin="0,0,8,0"/>

                                                <!-- Instruction -->
                                                <TextBox Grid.Column="4" 
                                                         x:Name="InstructionsInput"
                                                         Style="{StaticResource PremiumTextBoxStyle}"
                                                         Text="{Binding Instructions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="InstructionsInput_PreviewKeyDown"
                                                         Margin="0,0,8,0"/>

                                                <!-- Delete Row -->
                                                <Button Grid.Column="5" 
                                                        Content="×" 
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="0"
                                                        Height="34"
                                                        Width="34"
                                                        Click="DeleteRowButton_Click"
                                                        Tag="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Actions Bar -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                            Content="Clear Prescription" 
                            Style="{StaticResource SecondaryButtonStyle}" 
                            HorizontalAlignment="Left"
                            Click="ClearButton_Click"/>

                    <Button Grid.Column="1" 
                            Content="Print Prescription (Ctrl + P)" 
                            Style="{StaticResource PremiumButtonStyle}"
                            Click="PrintButton_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Right Column: Live Print Preview -->
        <Border Grid.Column="1" Background="#E2E8F0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Live Print Preview (Black &amp; White)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                <!-- A4 Aspect Box -->
                <Viewbox Grid.Row="1" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- A4 Dimension Paper Border: 794 x 1123 (96 DPI A4 size) -->
                    <Border x:Name="PrintPreviewPaper" 
                            Width="794" 
                            Height="1123" 
                            Background="#FFFFFF" 
                            BorderBrush="#94A3B8" 
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.15" ShadowDepth="4" Direction="270"/>
                        </Border.Effect>
                        
                        <!-- Page Contents (Matches physical A4 page layout exactly) -->
                        <Grid Margin="56,0,56,56"> <!-- 1.5cm lateral margins (approx. 56 pixels at 96 DPI) -->
                            <Grid.RowDefinitions>
                                <!-- Top 5cm (approx. 189 pixels at 96 DPI) blank space for pad header -->
                                <RowDefinition Height="189"/>
                                <!-- Patient Info Row (approx 75 pixels) -->
                                <RowDefinition Height="Auto"/>
                                <!-- Main Prescription Columns Grid -->
                                <RowDefinition Height="*"/>
                                <!-- Footer / Signature -->
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 5cm Header Blank Space -->
                            <Border Grid.Row="0" Background="Transparent"/>

                            <!-- Patient Info Row -->
                            <Grid Grid.Row="1" Margin="0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top border line -->
                                <!-- <Border Grid.Row="0" BorderBrush="#000000" BorderThickness="0,1,0,0" Height="2" Margin="0,0,0,8"/> -->

                                <!-- Patient Details -->
                                <Grid Grid.Row="1" Margin="4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>      <!-- Name -->
                                        <ColumnDefinition Width="Auto"/>   <!-- Age -->
                                        <ColumnDefinition Width="Auto"/>   <!-- Gender -->
                                        <ColumnDefinition Width="Auto"/>   <!-- Date -->
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Name -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Name: " FontWeight="Bold" FontSize="14" Foreground="#000000"/>
                                        <TextBlock Text="{Binding PatientName}" FontSize="14" Foreground="#000000"/>
                                    </StackPanel>

                                    <!-- Age -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Age: " FontWeight="Bold" FontSize="14" Foreground="#000000"/>
                                        <TextBlock Text="{Binding Age}" FontSize="14" Foreground="#000000"/>
                                    </StackPanel>

                                    <!-- Gender -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Gender: " FontWeight="Bold" FontSize="14" Foreground="#000000"/>
                                        <TextBlock Text="{Binding Gender}" FontSize="14" Foreground="#000000"/>
                                    </StackPanel>

                                    <!-- Date -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Date: " FontWeight="Bold" FontSize="14" Foreground="#000000"/>
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:dd-MM-yyyy}}" FontSize="14" Foreground="#000000"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Bottom border line -->
                                <Border Grid.Row="2" BorderBrush="#000000" BorderThickness="0,1,0,0" Height="2" Margin="0,8,0,0"/>
                            </Grid>

                            <!-- Main Body Split Columns -->
                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <!-- Left Column: Clinical Notes (5.5 cm = approx 208 pixels) -->
                                    <ColumnDefinition Width="208"/>
                                    <!-- Divider Line -->
                                    <ColumnDefinition Width="2"/>
                                    <!-- Right Column: Rx Medicines (Remaining 472 pixels) -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column (Clinical Notes) -->
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <StackPanel>
                                        <!-- Vitals Box -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="B.P: " FontWeight="Bold" FontSize="12" Foreground="#000000" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding BP}" FontSize="13" Foreground="#000000" Margin="0,0,0,10"/>

                                            <TextBlock Text="P.R: " FontWeight="Bold" FontSize="12" Foreground="#000000" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding PR}" FontSize="13" Foreground="#000000"/>
                                        </StackPanel>

                                        <!-- Complaints -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="C/O:" FontWeight="Bold" FontSize="12" Foreground="#000000" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding ChiefComplaints}" FontSize="13" Foreground="#000000" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Diagnosis -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="Most probable diagnosis:" FontWeight="Bold" FontSize="12" Foreground="#000000" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Diagnosis}" FontSize="13" Foreground="#000000" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Advice -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="Advice:" FontWeight="Bold" FontSize="12" Foreground="#000000" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Advice}" FontSize="13" Foreground="#000000" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Complications -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="Complications:" FontWeight="Bold" FontSize="12" Foreground="#000000" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Complication}" FontSize="13" Foreground="#000000" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Vertical Divider Line -->
                                <Border Grid.Column="1" Background="#000000" Width="1.5" VerticalAlignment="Stretch" Margin="0,-10,0,0"/>

                                <!-- Right Column (Rx Medicines) -->
                                <Grid Grid.Column="2" Margin="16,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Rx Symbol -->
                                        <RowDefinition Height="*"/>    <!-- Medicines List -->
                                    </Grid.RowDefinitions>

                                    <!-- Rx Symbol -->
                                    <TextBlock Grid.Row="0" Text="Rx," FontSize="36" FontWeight="ExtraBold" FontFamily="Times New Roman" Foreground="#000000" Margin="0,0,0,10"/>

                                    <!-- Medicines Items -->
                                    <StackPanel Grid.Row="1" Margin="0,4,0,0">
                                        <!-- General Physician Medicines -->
                                        <StackPanel Margin="0,0,0,20" Visibility="{Binding Medicines, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter='General Physician'}">
                                            
                                            <!-- Bordered Table -->
                                            <Border BorderBrush="#000000" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/> <!-- Header -->
                                                        <RowDefinition Height="*"/>    <!-- Rows -->
                                                    </Grid.RowDefinitions>
                                                    <!-- Table Header -->
                                                    <Grid Grid.Row="0" Background="#F3F4F6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>     <!-- SL -->
                                                            <ColumnDefinition Width="*"/>      <!-- Name -->
                                                            <ColumnDefinition Width="150"/>    <!-- Dosage (combined Dose + Instruction) -->
                                                            <ColumnDefinition Width="80"/>     <!-- Duration -->
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Border Grid.Column="0" BorderBrush="#000000" BorderThickness="0,0,1,1" Padding="4,6">
                                                            <TextBlock Text="SL" FontWeight="Bold" FontSize="12" Foreground="#000000" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <Border Grid.Column="1" BorderBrush="#000000" BorderThickness="0,0,1,1" Padding="8,6">
                                                            <TextBlock Text="Medicine and Composition" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                                                        </Border>
                                                        <Border Grid.Column="2" BorderBrush="#000000" BorderThickness="0,0,1,1" Padding="8,6">
                                                            <TextBlock Text="Dosage" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                                                        </Border>
                                                        <Border Grid.Column="3" BorderBrush="#000000" BorderThickness="0,0,0,1" Padding="8,6">
                                                            <TextBlock Text="Duration" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Table Rows -->
                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Medicines, Converter={StaticResource CategoryFilterConverter}, ConverterParameter='General Physician'}" AlternationCount="1000">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EvenOddBackgroundConverter}}">
                                                                    <Grid MinHeight="30">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="40"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="150"/>
                                                                            <ColumnDefinition Width="80"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- SL -->
                                                                        <Border Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Padding="4">
                                                                            <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource IndexConverter}}" 
                                                                                       FontWeight="Bold" FontSize="12" Foreground="#000000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>

                                                                        <!-- Name & Composition -->
                                                                        <Border Grid.Column="1" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Padding="8,4">
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding MedicineName}" FontWeight="SemiBold" FontSize="12" Foreground="#000000" TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding GenericName}" FontSize="10" Foreground="#475569" Margin="0,2,0,0" TextWrapping="Wrap" FontStyle="Italic" Visibility="{Binding GenericName, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"/>
                                                                            </StackPanel>
                                                                        </Border>

                                                                        <!-- Dosage -->
                                                                        <Border Grid.Column="2" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Padding="8,4">
                                                                            <TextBlock Text="{Binding DoseAndInstructions}" TextWrapping="Wrap" FontSize="12" Foreground="#000000" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <!-- Duration -->
                                                                        <Border Grid.Column=" 3" Padding="8,4">
                                                                            <TextBlock Text="{Binding Duration}" FontSize="12" Foreground="#000000" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- Skin & Hair Medicines -->
                                        <StackPanel Margin="0,0,0,20" Visibility="{Binding Medicines, Converter={StaticResource CategoryVisibilityConverter}, ConverterParameter='Skin &amp; Hair'}">
                                            
                                            <!-- Bordered Table -->
                                            <Border BorderBrush="#000000" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/> <!-- Header -->
                                                        <RowDefinition Height="*"/>    <!-- Rows -->
                                                    </Grid.RowDefinitions>

                                                    <!-- Table Header -->
                                                    <Grid Grid.Row="0" Background="#F3F4F6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>     <!-- SL -->
                                                            <ColumnDefinition Width="*"/>      <!-- Name -->
                                                            <ColumnDefinition Width="150"/>    <!-- Dosage (combined Dose + Instruction) -->
                                                            <ColumnDefinition Width="80"/>     <!-- Duration -->
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" BorderBrush="#000000" BorderThickness="0,0,1,1" Padding="4,6">
                                                            <TextBlock Text="SL" FontWeight="Bold" FontSize="12" Foreground="#000000" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <Border Grid.Column="1" BorderBrush="#000000" BorderThickness="0,0,1,1" Padding="8,6">
                                                            <TextBlock Text="Medicine and Composition" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                                                        </Border>
                                                        <Border Grid.Column="2" BorderBrush="#000000" BorderThickness="0,0,1,1" Padding="8,6">
                                                            <TextBlock Text="Dosage" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                                                        </Border>
                                                        <Border Grid.Column="3" BorderBrush="#000000" BorderThickness="0,0,0,1" Padding="8,6">
                                                            <TextBlock Text="Duration" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Table Rows -->
                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Medicines, Converter={StaticResource CategoryFilterConverter}, ConverterParameter='Skin &amp; Hair'}" AlternationCount="1000">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EvenOddBackgroundConverter}}">
                                                                    <Grid MinHeight="30">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="40"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="150"/>
                                                                            <ColumnDefinition Width="80"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- SL -->
                                                                        <Border Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Padding="4">
                                                                            <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource IndexConverter}}" 
                                                                                       FontWeight="Bold" FontSize="12" Foreground="#000000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>

                                                                        <!-- Name & Composition -->
                                                                        <Border Grid.Column="1" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Padding="8,4">
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding MedicineName}" FontWeight="SemiBold" FontSize="12" Foreground="#000000" TextWrapping="Wrap"/>
                                                                                <TextBlock Text="{Binding GenericName}" FontSize="10" Foreground="#475569" Margin="0,2,0,0" TextWrapping="Wrap" FontStyle="Italic" Visibility="{Binding GenericName, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"/>
                                                                            </StackPanel>
                                                                        </Border>

                                                                        <!-- Dosage -->
                                                                        <Border Grid.Column="2" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0" Padding="8,4">
                                                                            <TextBlock Text="{Binding DoseAndInstructions}" TextWrapping="Wrap" FontSize="12" Foreground="#000000" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <!-- Duration -->
                                                                         <Border Grid.Column=" 3" Padding="8,4">
                                                                             <TextBlock Text="{Binding Duration}" FontSize="12" Foreground="#000000" VerticalAlignment="Center"/>
                                                                         </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                         </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- Signature and Date Footer Area -->
                            <Grid Grid.Row="3" Margin="0,30,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1" BorderBrush="#000000" BorderThickness="0,1,0,0" Width="180" Padding="0,6,0,0">
                                    <TextBlock Text="Doctor's Signature" FontSize="12" Foreground="#000000" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Viewbox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
