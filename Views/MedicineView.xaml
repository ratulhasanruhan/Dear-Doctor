<UserControl x:Class="Dear_Doctor.Views.MedicineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Medicine Database" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Add, update, and manage your local medicine suggestions" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" 
                    Content="+ Add New Medicine" 
                    Style="{StaticResource PremiumButtonStyle}"
                    Click="AddMedicineButton_Click"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="EditColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Left: List and Search -->
            <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Margin="0,0,8,0">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar & Category Filter -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="0">
                            <TextBox x:Name="SearchBox" 
                                     Style="{StaticResource PremiumTextBoxStyle}"
                                     TextChanged="SearchBox_TextChanged"/>
                            <!-- Watermark/Placeholder overlay for search -->
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="Search medicines by name or generic name..." 
                                       Foreground="#94A3B8" 
                                       FontSize="14" 
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Margin="12,0,0,0"
                                       Visibility="Visible"/>
                        </Grid>
                        
                        <ComboBox x:Name="CategoryFilterComboBox" 
                                  Grid.Column="1" 
                                  Height="38" 
                                  Margin="8,0,0,0"
                                  SelectedValuePath="Content"
                                  SelectedIndex="0"
                                  SelectionChanged="CategoryFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="All Categories"/>
                            <ComboBoxItem Content="General Physician"/>
                            <ComboBoxItem Content="Skin &amp; Hair"/>
                        </ComboBox>
                    </Grid>

                    <!-- Medicines List -->
                    <ListView x:Name="MedicinesListView" 
                              Grid.Row="1" 
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                <Setter Property="Padding" Value="12,14"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                                        <WrapPanel Margin="0,4,0,0">
                                            <!-- Category tag -->
                                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Category}" Value="Skin &amp; Hair">
                                                                <Setter Property="Background" Value="#FAE8FF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="General Physician">
                                                                <Setter Property="Background" Value="#CCFBF1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Category}"/>
                                                            <Setter Property="Foreground" Value="#475569"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Category}" Value="Skin &amp; Hair">
                                                                    <Setter Property="Foreground" Value="#A855F7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Category}" Value="General Physician">
                                                                    <Setter Property="Foreground" Value="#0D9488"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            
                                            <Border Background="#F1F5F9" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding GenericName}" FontSize="11" Foreground="#475569" FontWeight="Medium"/>
                                            </Border>
                                            <TextBlock Text="Dose: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding DefaultDose}" FontSize="12" Foreground="#0F766E" FontWeight="Medium" Margin="0,0,12,0"/>
                                            
                                            <TextBlock Text="Duration: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding DefaultDuration}" FontSize="12" Foreground="#0F766E" FontWeight="Medium" Margin="0,0,12,0"/>

                                            <TextBlock Text="Advice: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding DefaultInstructions}" FontSize="12" Foreground="#475569"/>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Edit" 
                                                Style="{StaticResource SecondaryButtonStyle}" 
                                                Padding="12,6" 
                                                Margin="0,0,6,0"
                                                Click="EditMedicine_Click"
                                                Tag="{Binding}"/>
                                        <Button Content="Delete" 
                                                Style="{StaticResource DangerButtonStyle}" 
                                                Padding="12,6"
                                                Click="DeleteMedicine_Click"
                                                Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right: Edit Drawer Panel -->
            <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Margin="8,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock x:Name="DrawerTitle" Text="Add Medicine" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                        <Border Height="1" Background="#E2E8F0" Margin="0,8,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,4,0">
                            <!-- Name -->
                            <TextBlock Text="Medicine Name (with brand/strength)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" FontSize="13"/>
                            <TextBox x:Name="MedicineNameInput" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,16"/>

                            <!-- Category -->
                            <TextBlock Text="Category" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" FontSize="13"/>
                            <ComboBox x:Name="CategoryInput" Height="38" Margin="0,0,0,16" SelectedValuePath="Content" SelectedIndex="0">
                                <ComboBoxItem Content="General Physician"/>
                                <ComboBoxItem Content="Skin &amp; Hair"/>
                            </ComboBox>

                            <!-- Generic Name -->
                            <TextBlock Text="Generic Name / Composition" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" FontSize="13"/>
                            <TextBox x:Name="GenericNameInput" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,16"/>

                            <!-- Default Dose -->
                            <TextBlock Text="Default Dosage (e.g., 1+0+1)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" FontSize="13"/>
                            <TextBox x:Name="DefaultDoseInput" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,16"/>

                            <!-- Default Duration -->
                            <TextBlock Text="Default Duration (e.g., 7 days)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" FontSize="13"/>
                            <TextBox x:Name="DefaultDurationInput" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,16"/>

                            <!-- Default Instructions -->
                            <TextBlock Text="Default Instructions (e.g., After food)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" FontSize="13"/>
                            <TextBox x:Name="DefaultInstructionsInput" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,16"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="CancelEditButton_Click"/>
                        <Button Grid.Column="1" Content="Save" Style="{StaticResource PremiumButtonStyle}" Margin="6,0,0,0" Click="SaveMedicineButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
